<script>
  document.addEventListener('DOMContentLoaded', function() {
    // 1. Funcionalidade de Adição ao Carrinho (AJAX)
    const quickAddButtons = document.querySelectorAll('.quick-add');
    
    quickAddButtons.forEach(button => {
      button.addEventListener('click', function(e) {
        e.preventDefault();
        const variantId = this.dataset.variantId;
        const btnText = this.querySelector('.btn-text');
        const spinner = this.querySelector('.loading-overlay__spinner');
        
        // Feedback Visual: Loading
        this.classList.add('loading');
        spinner.classList.remove('hidden');
        btnText.textContent = 'Adicionando...';
        this.disabled = true;

        let formData = {
          'items': [{
            'id': variantId,
            'quantity': 1
          }]
        };

        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(formData)
        })
        .then(response => response.json())
        .then(data => {
          // Feedback Sucesso
          this.classList.remove('loading');
          this.classList.add('success');
          spinner.classList.add('hidden');
          btnText.textContent = 'Adicionado! ✓';
          
          // Abrir o Cart Drawer (se configurado no tema)
          if (document.querySelector('cart-drawer')) {
            document.querySelector('cart-drawer').classList.add('active');
            // Trigger Dawn cart update event
            document.dispatchEvent(new CustomEvent('cart:build'));
            // If the theme is Dawn and uses cart-drawer.js
            const cartDrawer = document.querySelector('cart-drawer');
            if (cartDrawer && typeof cartDrawer.renderContents === 'function') {
               cartDrawer.renderContents(data);
            } else {
               // Fallback: Atualiza a página ou abre o drawer via classe
               location.reload(); 
            }
          } else {
            window.location.href = window.Shopify.routes.root + 'cart';
          }
        })
        .catch((error) => {
          console.error('Error:', error);
          btnText.textContent = 'Erro ao adicionar';
          this.disabled = false;
        })
        .finally(() => {
          setTimeout(() => {
            if (!this.classList.contains('error')) {
               btnText.textContent = 'Adicionar ao Pedido';
               this.classList.remove('success');
               this.disabled = false;
            }
          }, 2000);
        });
      });
    });

    // 2. Funcionalidade de Busca do Portal
    const searchInput = document.getElementById('vet-product-search');
    if (searchInput) {
      searchInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
          const query = encodeURIComponent(this.value);
          if (query) {
             window.location.href = `/search?q=${query}&options[prefix]=last&type=product`;
          }
        }
      });
    }

    // 3. Banner de Upsell (Exemplo de clique)
    const upsellBtn = document.querySelector('.upsell-banner-premium .button');
    if (upsellBtn) {
       upsellBtn.onclick = () => {
          window.location.href = '/collections/acessorios-hospitalares';
       };
    }
  });
</script>

