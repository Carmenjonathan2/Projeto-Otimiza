{% comment %}
  Portal Exclusivo para Médicos Veterinários
  Inclui Vitrine de Ofertas, Upsell e Cross-sell
{% endcomment %}

{% comment %}
  Controle de Acesso: Apenas veterinários com tag 'veterinario' podem ver este conteúdo
{% endcomment %}
{%- render 'snippet-acesso-restrito' -%}


<div class="vet-portal-wrapper color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    
    <!-- Header de Boas Vindas -->
    <header class="portal-header">
      <div class="welcome-container">
        <div class="welcome-text">
          <span class="portal-tag">PORTAL B2B PROFISSIONAL</span>
          <h1>Bem-vindo(a), {{ customer.first_name }}</h1>
          <p>Seu centro de suprimentos com preços de atacado, ofertas de volume e reposição rápida de estoque clínica.</p>
        </div>
        <div class="vet-badge-premium">
          <div class="badge-ring">
            <span class="badge-icon">✓</span>
          </div>
          <div class="badge-content">
            <strong>Clínica Verificada</strong>
            <span>Tabela Atacado Ativa</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Barra de Ferramentas Rápida -->
    <div class="portal-tools">
      <div class="search-box">
        <input type="text" placeholder="Buscar vacinas, agulhas, luvas ou insumos hospitalares..." id="vet-product-search">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </div>
      <div class="quick-links">
        <a href="https://wa.me/5531987936822?text=Olá! Preciso de suporte ou cotação para reposição de estoque clínico." class="tool-link">
          <span class="tool-icon">📱</span> Suporte no WhatsApp
        </a>
        <a href="{{ routes.account_url }}" class="tool-link">
          <span class="tool-icon">🕒</span> Pedidos Recentes
        </a>
      </div>
    </div>



    <!-- Bloco de Benefícios Profissionais -->
    <div class="vet-benefits-bar">
      <div class="benefit-item">
        <span class="benefit-icon">💰</span>
        <div class="benefit-text">
          <strong>Preço de Atacado</strong>
          <span>Exclusivo p/ CRMV</span>
        </div>
      </div>
      <div class="benefit-item">
        <span class="benefit-icon">🚚</span>
        <div class="benefit-text">
          <strong>Frete Prioritário</strong>
          <span>Logística Agilizada</span>
        </div>
      </div>
      <div class="benefit-item">
        <span class="benefit-icon">💳</span>
        <div class="benefit-text">
          <strong>Faturamento B2B</strong>
          <span>Opções no Boleto</span>
        </div>
      </div>
      <div class="benefit-item">
        <span class="benefit-icon">📈</span>
        <div class="benefit-text">
          <strong>Programas de Ciclo</strong>
          <span>Bônus por Volume</span>
        </div>
      </div>
    </div>

    <!-- Banner de Condições de Pagamento -->
    <div class="vet-payment-info-banner">
      <div class="payment-info-content">
        <div class="payment-badges">
          <span class="p-badge">📄 Boleto Faturado</span>
          <span class="p-badge">🏦 PIX Automático</span>
          <span class="p-badge">💳 Cartão de Crédito</span>
        </div>
        <div class="payment-text">
          <p><strong>Condições Especiais B2B:</strong> Faturamento direto via Boleto para clínicas cadastradas. Parcelamento em até 12x disponível (com incidência de juros conforme legislação vigente).</p>
        </div>
      </div>
    </div>

    <!-- Seção de Ofertas Exclusivas (Uso Veterinário) -->
    <section class="portal-section">
      <div class="portal-grid grid grid--2-col-tablet-down grid--4-col-desktop">
        {%- assign vet_products_count = 0 -%}
        {%- for product in section.settings.collection.products -%}
          {%- assign vet_products_count = vet_products_count | plus: 1 -%}
          {%- liquid
            assign current_variant = product.selected_or_first_available_variant
            assign price = current_variant.price
            assign compare_at_price = current_variant.compare_at_price
          -%}
          
          <div class="grid__item portal-product-card card-premium-vet">
            <div class="card-badges">
              {% if product.tags contains 'Destaque' or product.tags contains 'destaque' %}
                <span class="badge-destaque">Destaque</span>
              {% endif %}
              {% if product.tags contains 'Novidade' or product.tags contains 'novidade' %}
                <span class="badge-novidade">Novidade</span>
              {% endif %}
            </div>

            <div class="card-image">
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" loading="lazy">
            </div>

            <div class="card-info">
              <h3 class="product-title">{{ product.title }}</h3>
              
              <div class="price-container">
                {% if compare_at_price > price %}
                  <div class="original-price-row">
                     <span class="price-strikethrough">{{ compare_at_price | money }}</span>
                  </div>
                {% endif %}
                
                <div class="cash-price-row">
                  <span class="cash-value">{{ price | money }}</span>
                  <span class="cash-label">Valor</span>
                </div>
              </div>

              <button class="button--portal-add quick-add" data-variant-id="{{ current_variant.id }}">
                <span class="btn-icon">+</span> 
                <span class="btn-text">Adicionar ao Pedido</span>
                <div class="loading-overlay__spinner hidden">
                  <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                    <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                  </svg>
                </div>
              </button>
            </div>
          </div>
          {%- if vet_products_count >= 12 -%}{%- break -%}{%- endif -%}
        {%- endfor -%}
        
        {%- if vet_products_count == 0 -%}
          <div class="empty-state">
            <p>Nenhuma oferta ativa nesta coleção no momento.</p>
          </div>
        {%- endif -%}
      </div>
    </section>
    <!-- Pedidos Frequentes e Acesso Rápido -->
    <section class="portal-section frequent-items">
      <div class="section-header">
        <div class="header-text">
          <h2>📦 Itens de Alta Frequência</h2>
          <p>Localize e reponha rapidamente os produtos mais utilizados na sua rotina.</p>
        </div>
      </div>
      
      <div class="frequent-grid">
        <div class="frequent-card primary-action">
          <div class="frequent-info">
            <span class="frequent-icon">📞</span>
            <h3>Cotação Personalizada</h3>
            <p>Precisa de um item que não está aqui? Chame nosso consultor B2B no WhatsApp.</p>
            <a href="https://wa.me/5531987936822?text=Olá! Gostaria de uma cotação para itens específicos da minha clínica." class="button button--secondary">Chamar Consultor</a>
          </div>
        </div>

        <div class="frequent-card item-fast">
          <div class="item-visual">💊</div>
          <div class="item-details">
            <h4>Reposição Neptra</h4>
            <p>O tratamento de dose única mais pedido pelas clínicas.</p>
            <a href="/search?q=neptra" class="item-link">Ver Opções →</a>
          </div>
        </div>



        <div class="frequent-card item-fast">
          <div class="item-visual">✂️</div>
          <div class="item-details">
            <h4>Insumos Cirúrgicos</h4>
            <p>Fios de sutura, gazes e descartáveis hospitalares.</p>
            <a href="/search?q=cirurgico" class="item-link">Repor Estoque →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Banner de Upsell / Combo de Insumos -->
    <section class="upsell-banner-premium">
      <div class="upsell-content">
        <span class="upsell-tag">REPOSIÇÃO ESSENCIAL</span>
        <h2>Kit Seringas & Agulhas</h2>
        <p>Garanta o estoque de acessórios! Adicione uma caixa de Seringas (100un) ao seu pedido e ganhe <strong>10% de desconto extra</strong> no total da sua compra.</p>
        <div class="upsell-footer">
          <button class="button button--secondary">Adicionar Combo Insumos</button>
          <span class="upsell-timer">Oferta para volume: <strong>Ativa</strong></span>
        </div>
      </div>
      <div class="upsell-visual">
         <div class="visual-accent"></div>
         <div class="visual-circle"></div>
      </div>
    </section>

  </div>
</div>

