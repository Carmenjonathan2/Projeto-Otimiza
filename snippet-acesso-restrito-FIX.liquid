{%- liquid
  assign is_vet = false
  if customer
    for tag in customer.tags
      assign lower_tag = tag | downcase
      if lower_tag == 'veterinario'
        assign is_vet = true
      endif
    endfor
  endif
-%}

{%- unless is_vet -%}
  <div style="position:fixed;top:0;left:0;width:100%;height:100%;background:white;z-index:9999;display:flex;align-items:center;justify-content:center;text-align:center;padding:20px;font-family:sans-serif;">
    <div style="max-width:400px;border:1px solid #eee;padding:40px;border-radius:15px;box-shadow:0 10px 30px rgba(0,0,0,0.1);">
      <h2 style="color:#1a4d33;">Acesso Restrito</h2>
      <p>Esta area e exclusiva para Medicos Veterinarios cadastrados.</p>
      {% if customer %}
        <p style="color:orange;">Seu cadastro esta em analise. Verificaremos seu CRMV em breve.</p>
      {% else %}
        <a href="/account/login" style="display:block;background:#1a4d33;color:white;padding:12px;text-decoration:none;border-radius:5px;margin-bottom:10px;">Fazer Login</a>
        <a href="/pages/cadastro-veterinario" style="color:#1a4d33;">Solicitar Acesso Profissional</a>
      {% endif %}
    </div>
  </div>
  <script>window.stop();</script>
{%- endunless -%}
