# ─── Z-API (WhatsApp) ─────────────────────────────────────────────────────────
ZAPI_INSTANCE_ID=SEU_INSTANCE_ID
ZAPI_TOKEN=SEU_TOKEN
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN

# ─── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=SUA_CHAVE_GEMINI

# ─── GestãoClick ERP ─────────────────────────────────────────────────────────
GESTAOCLICK_ACCESS_TOKEN=SEU_ACCESS_TOKEN
GESTAOCLICK_SECRET_TOKEN=SEU_SECRET_TOKEN
GC_CACHE_ENABLED=true
GC_CACHE_TTL_SECONDS=3600

# Cache de estoque (consulta real-time à API GestãoClick, TTL em segundos)
# 300 = 5 minutos — equilíbrio entre frescor e número de chamadas à API
ESTOQUE_CACHE_TTL_SECONDS=300

# ─── Chatwoot ─────────────────────────────────────────────────────────────────
CHATWOOT_API_URL=https://app.chatwoot.com
CHATWOOT_API_KEY=SUA_API_KEY
CHATWOOT_ACCOUNT_ID=SEU_ACCOUNT_ID
CHATWOOT_INBOX_ID=SEU_INBOX_ID

# ─── Telegram (alertas internos) ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=SEU_BOT_TOKEN
TELEGRAM_CHAT_ID=SEU_CHAT_ID
TELEGRAM_CHAT_IDS=SEU_CHAT_ID

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── Comportamento do bot ─────────────────────────────────────────────────────
# true = bot sugere resposta mas não envia (modo copiloto para testes)
MODO_SILENCIOSO=true
MODO_TESTE=false

# Horário comercial (formato HH no fuso do servidor)
HORARIO_COMERCIAL_INICIO=8
HORARIO_COMERCIAL_FIM=19
ATENDE_DOMINGO=false

# Rate limiting por número (janela em segundos)
RATE_LIMIT_MAX_MSG=10
RATE_LIMIT_JANELA_SEGUNDOS=60

# Tempo mínimo entre processamentos do mesmo número (ms)
LOCK_PROCESSAMENTO_MS=1500
