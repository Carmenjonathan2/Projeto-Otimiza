{% comment %}
  Formulário de Registro Exclusivo para Médicos Veterinários
  Este formulário adiciona tags específicas para posterior aprovação.
{% endcomment %}

<div class="vet-registration-container">
  <div class="registration-header">
    <h2>Cadastramento Profissional - Otimiza FarmaVet</h2>
    <p>Acesso exclusivo para Médicos Veterinários. Preencha os dados abaixo para análise de perfil.</p>
  </div>

  {%- form 'create_customer', class: 'vet-form' -%}
    {{ form.errors | default_errors }}

    <div class="field">
      <input
        type="text"
        name="customer[first_name]"
        id="RegisterForm-FirstName"
        {% if form.first_name %}value="{{ form.first_name }}"{% endif %}
        autocomplete="given-name"
        placeholder="Nome"
        required
      >
      <label for="RegisterForm-FirstName">Nome</label>
    </div>

    <div class="field">
      <input
        type="text"
        name="customer[last_name]"
        id="RegisterForm-LastName"
        {% if form.last_name %}value="{{ form.last_name }}"{% endif %}
        autocomplete="family-name"
        placeholder="Sobrenome"
        required
      >
      <label for="RegisterForm-LastName">Sobrenome</label>
    </div>

    <div class="field">
      <input
        type="email"
        name="customer[email]"
        id="RegisterForm-email"
        {% if form.email %}value="{{ form.email }}"{% endif %}
        spellcheck="false"
        autocapitalize="off"
        autocomplete="email"
        aria-required="true"
        {% if form.errors contains 'email' %}
          aria-invalid="true"
          aria-describedby="RegisterForm-email-error"
        {% endif %}
        placeholder="E-mail Profissional"
        required
      >
      <label for="RegisterForm-email">E-mail Profissional</label>
    </div>

    <div class="field">
      <input
        type="text"
        name="customer[note][CRMV]"
        id="RegisterForm-CRMV"
        placeholder="Número do CRMV + UF"
        required
      >
      <label for="RegisterForm-CRMV">Número do CRMV (Ex: 12345/MG)</label>
    </div>

    <div class="field">
      <input
        type="tel"
        name="customer[note][Telefone]"
        id="RegisterForm-Phone"
        placeholder="WhatsApp / Telefone"
        required
      >
      <label for="RegisterForm-Phone">WhatsApp para Contato</label>
    </div>

    <div class="field">
      <input
        type="password"
        name="customer[password]"
        id="RegisterForm-password"
        aria-required="true"
        {% if form.errors contains 'password' %}
          aria-invalid="true"
          aria-describedby="RegisterForm-password-error"
        {% endif %}
        placeholder="Senha"
        required
      >
      <label for="RegisterForm-password">Defina sua Senha</label>
    </div>

    {%- comment -%} Tag oculta para identificar o tipo de conta {%- endcomment -%}
    <input type="hidden" name="customer[tags]" value="proposito:veterinario, aprovacao:pendente">

    <div class="form-actions">
      <button class="button button--primary full-width">
        Solicitar Acesso à Área do Veterinário
      </button>
    </div>

    <p class="form-footer">
      Já possui cadastro? <a href="/account/login">Fazer login</a>
    </p>

  {%- endform -%}
</div>

<style>
.vet-registration-container {
  max-width: 500px;
  margin: 40px auto;
  padding: 30px;
  background: #ffffff;
  border-radius: 12px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.08);
}

.registration-header {
  text-align: center;
  margin-bottom: 30px;
}

.registration-header h2 {
  color: #1a4d33; /* Cor institucional / Farmavet */
  margin-bottom: 10px;
}

.registration-header p {
  font-size: 1.4rem;
  color: #666;
}

.vet-form .field {
  margin-bottom: 20px;
}

.vet-form input {
  width: 100%;
  padding: 12px;
  border: 1px solid #e0e0e0;
  border-radius: 6px;
  transition: border-color 0.3s ease;
}

.vet-form input:focus {
  border-color: #1a4d33;
  outline: none;
}

.form-actions {
  margin-top: 30px;
}

.form-footer {
  text-align: center;
  margin-top: 20px;
  font-size: 1.3rem;
}

.form-footer a {
  color: #1a4d33;
  font-weight: bold;
}
</style>
