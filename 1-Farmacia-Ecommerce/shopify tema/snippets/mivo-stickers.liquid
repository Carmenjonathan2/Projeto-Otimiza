{% comment %}
  MIVO STICKERS - PREMIUM FLOATING STICKERS SNIPPET
  Inspirado no Tema MIVO (BoostifyThemes) - Criado para Otimiza FarmaVet
  ========================================================================
  Uso: {% render 'mivo-stickers', type: 'b2c' %} ou {% render 'mivo-stickers', type: 'servico' %}
{% endcomment %}

<div class="mivo-sticker-container">
  {% if type == 'b2c' or type == 'all' %}
    <!-- Flower Sticker Left -->
    <svg class="mivo-sticker float-slow spin-slow" style="top: 15%; left: 4%; width: 70px; height: 70px; fill: var(--mivo-lilac-suave); stroke: var(--mivo-primary); stroke-width: 2;" viewBox="0 0 100 100">
      <path d="M50 15 C40 15 35 25 45 35 C35 25 25 30 25 40 C25 50 35 55 45 45 C35 55 30 65 40 75 C50 85 55 75 45 65 C55 75 65 70 75 60 C85 50 75 45 65 45 C75 45 80 35 70 25 C60 15 55 25 50 15 Z" />
      <circle cx="50" cy="45" r="10" fill="var(--mivo-accent)" />
    </svg>

    <!-- Sparkle Sticker Right -->
    <svg class="mivo-sticker float-fast" style="top: 25%; right: 5%; width: 45px; height: 45px; fill: var(--mivo-accent); filter: drop-shadow(0 0 5px rgba(255, 184, 0, 0.4));" viewBox="0 0 24 24">
      <path d="M12 2L15 9L22 12L15 15L12 22L9 15L2 12L9 9Z" />
    </svg>
  {% endif %}

  {% if type == 'servico' or type == 'all' %}
    <!-- Paw Sticker Left -->
    <svg class="mivo-sticker float-fast" style="bottom: 15%; left: 8%; width: 60px; height: 60px; fill: var(--mivo-lilac-off); stroke: var(--mivo-lilac-suave); stroke-width: 2.5;" viewBox="0 0 100 100">
      <!-- Main Pad -->
      <path d="M30 60 C25 75 40 85 50 82 C60 85 75 75 70 60 C65 50 35 50 30 60 Z" />
      <!-- Digital Pads -->
      <circle cx="22" cy="40" r="8" />
      <circle cx="38" cy="24" r="9" />
      <circle cx="62" cy="24" r="9" />
      <circle cx="78" cy="40" r="8" />
    </svg>

    <!-- Sparkle Sticker Right -->
    <svg class="mivo-sticker float-slow" style="top: 10%; right: 10%; width: 45px; height: 45px; fill: var(--mivo-accent);" viewBox="0 0 24 24">
      <path d="M12 2L15 9L22 12L15 15L12 22L9 15L2 12L9 9Z" />
    </svg>
  {% endif %}

  {% if type == 'b2b' or type == 'all' %}
    <!-- Heart Sticker Left -->
    <svg class="mivo-sticker float-slow" style="top: 15%; left: 6%; width: 50px; height: 50px; fill: #FF7EB9; stroke: var(--mivo-primary); stroke-width: 2;" viewBox="0 0 100 100">
      <path d="M50 80 C20 60 10 35 30 20 C45 10 50 30 50 30 C50 30 55 10 70 20 C90 35 80 60 50 80 Z" />
    </svg>

    <!-- Flower Sticker Right -->
    <svg class="mivo-sticker float-fast spin-slow" style="bottom: 20%; right: 7%; width: 70px; height: 70px; fill: var(--mivo-lilac-suave); stroke: var(--mivo-primary); stroke-width: 2;" viewBox="0 0 100 100">
      <path d="M50 15 C40 15 35 25 45 35 C35 25 25 30 25 40 C25 50 35 55 45 45 C35 55 30 65 40 75 C50 85 55 75 45 65 C55 75 65 70 75 60 C85 50 75 45 65 45 C75 45 80 35 70 25 C60 15 55 25 50 15 Z" />
      <circle cx="50" cy="45" r="10" fill="var(--mivo-accent)" />
    </svg>
  {% endif %}
</div>
