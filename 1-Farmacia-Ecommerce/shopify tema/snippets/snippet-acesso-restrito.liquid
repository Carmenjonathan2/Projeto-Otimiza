{% comment %}
  Controle de Acesso Exclusivo para Veterinários - VERSÃO FINAL
  IMPORTANTE: Este snippet deve ser usado APENAS na página do portal veterinário
  NÃO adicione este snippet no theme.liquid ou em templates globais!
{% endcomment %}

{%- liquid
  assign is_vet = false
  if customer
    for tag in customer.tags
      assign lower_tag = tag | downcase
      if lower_tag == 'veterinario'
        assign is_vet = true
        break
      endif
    endfor
  endif

  # Garantir que a página de cadastro nunca seja bloqueada
  assign is_registration_page = false
  if request.path contains 'cadastro-veterinario' or page.handle == 'cadastro-veterinario'
    assign is_registration_page = true
  endif
-%}

{%- unless is_vet or is_registration_page or request.design_mode -%}
  <div class="vet-access-restriction">
    <div class="restriction-modal">
      <div class="restriction-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
      </div>
      <h2>Área Restrita: Médicos Veterinários</h2>
      <p>Esta página é dedicada exclusivamente a profissionais cadastrados e aprovados pela Otimiza FarmaVet.</p>
      
      <div class="restriction-buttons">
        {%- if customer -%}
          <div class="status-alert">
            <strong>Aguardando aprovação</strong>
            <p>Seu registro profissional está em análise. Nossa equipe verificará seu CRMV em breve.</p>
          </div>
        {%- else -%}
          <a href="/account/login" class="btn-primary" style="display: block !important; visibility: visible !important; opacity: 1 !important;">Fazer Login</a>
          <a href="/pages/cadastro-veterinario" class="btn-secondary" style="display: block !important; visibility: visible !important; opacity: 1 !important;">Solicitar Acesso</a>
        {%- endif -%}
      </div>
      
      <a href="{{ routes.root_url }}" class="link-back">← Retornar à loja pública</a>
    </div>
  </div>

  <style>
    /* Overlay de restrição - APENAS PARA ESTA PÁGINA */
    .vet-access-restriction {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      width: 100%;
      height: 100%;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(10px);
      z-index: 2147483647;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      overflow: auto;
      pointer-events: auto;
    }

    /* FAILSAFE: Se estiver no editor do Shopify, o bloqueio NUNCA aparece */
    .shopify-design-mode .vet-access-restriction {
      display: none !important;
      visibility: hidden !important;
      opacity: 0 !important;
      pointer-events: none !important;
    }
    
    .restriction-modal {
      max-width: 480px;
      width: 100%;
      text-align: center;
      padding: 50px 40px;
      background: #ffffff;
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
      border: 1px solid #f0f0f0;
      position: relative;
      z-index: 2147483647;
      pointer-events: auto;
    }
    
    .restriction-icon {
      margin-bottom: 25px;
      color: #1a4d33;
    }
    
    .restriction-icon svg {
      width: 64px;
      height: 64px;
    }
    
    .restriction-modal h2 {
      color: #1a4d33;
      font-size: 2.4rem;
      font-weight: 700;
      margin: 0 0 15px 0;
      line-height: 1.3;
    }
    
    .restriction-modal > p {
      color: #666;
      font-size: 1.5rem;
      line-height: 1.6;
      margin: 0 0 30px 0;
    }
    
    .restriction-buttons {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 25px;
      position: relative;
      z-index: 2147483647;
    }
    
    .status-alert {
      background: #fff8e1;
      border: 1px solid #ffd54f;
      border-radius: 10px;
      padding: 20px;
      color: #b78103;
    }
    
    .status-alert strong {
      display: block;
      font-size: 1.6rem;
      margin-bottom: 8px;
    }
    
    .status-alert p {
      margin: 0;
      font-size: 1.4rem;
      color: #8b6914;
    }
    
    .btn-primary,
    .btn-secondary {
      display: block;
      padding: 14px 28px;
      border-radius: 8px;
      font-size: 1.5rem;
      font-weight: 600;
      text-decoration: none;
      text-align: center;
      transition: all 0.3s ease;
      position: relative;
      z-index: 2147483647;
      cursor: pointer !important;
      pointer-events: auto !important;
    }
    
    .btn-primary {
      background: #1a4d33;
      color: #ffffff;
      border: 1px solid #1a4d33;
    }
    
    .btn-primary:hover {
      background: #2e7d32;
      border-color: #2e7d32;
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(26, 77, 51, 0.3);
    }
    
    .btn-secondary {
      background: transparent;
      color: #1a4d33;
      border: 2px solid #1a4d33;
    }
    
    .btn-secondary:hover {
      background: #f1f8f4;
    }
    
    .link-back {
      display: inline-block;
      margin-top: 15px;
      color: #999;
      font-size: 1.4rem;
      text-decoration: none;
      transition: color 0.3s ease;
      position: relative;
      z-index: 2147483647;
      cursor: pointer !important;
      pointer-events: auto !important;
    }
    
    .link-back:hover {
      color: #1a4d33;
      text-decoration: underline;
    }
    
    @media (max-width: 768px) {
      .restriction-modal {
        padding: 35px 25px;
      }
      
      .restriction-modal h2 {
        font-size: 2rem;
      }
      
      .restriction-modal > p {
        font-size: 1.4rem;
      }
    }
  </style>
{%- endunless -%}
