{% comment %}
  MIVO DIVIDERS - PREMIUM CURVED/WAVY SECTION DIVIDER SNIPPET
  Inspirado no Tema MIVO (BoostifyThemes) - Criado para Otimiza FarmaVet
  ========================================================================
  Uso: {% render 'mivo-dividers', position: 'bottom', color: '#F8EEFA' %}
{% endcomment %}

<div class="mivo-divider-wrapper" style="pointer-events: none;">
  {% if position == 'bottom' %}
    <!-- Wave transitioning downward -->
    <svg class="mivo-divider-svg bottom-curve" viewBox="0 0 1440 120" preserveAspectRatio="none" style="fill: {{ color | default: '#F8EEFA' }};">
      <path d="M0,32L80,37.3C160,43,320,53,480,48C640,43,800,21,960,16C1120,11,1280,21,1360,26.7L1440,32L1440,120L1360,120C1280,120,1120,120,960,120C800,120,640,120,480,120C320,120,160,120,80,120L0,120Z"></path>
    </svg>
  {% elsif position == 'top' %}
    <!-- Wave transitioning upward (flipped) -->
    <svg class="mivo-divider-svg top-curve" viewBox="0 0 1440 120" preserveAspectRatio="none" style="fill: {{ color | default: '#FAF7FC' }};">
      <path d="M0,32L80,37.3C160,43,320,53,480,48C640,43,800,21,960,16C1120,11,1280,21,1360,26.7L1440,32L1440,120L1360,120C1280,120,1120,120,960,120C800,120,640,120,480,120C320,120,160,120,80,120L0,120Z"></path>
    </svg>
  {% elsif position == 'hills' %}
    <!-- Soft rolling hills wave -->
    <svg class="mivo-divider-svg bottom-curve" viewBox="0 0 1440 120" preserveAspectRatio="none" style="fill: {{ color | default: '#F8EEFA' }};">
      <path d="M0,96L80,85.3C160,75,320,53,480,53C640,53,800,75,960,85.3C1120,96,1280,96,1360,96L1440,96L1440,120L1360,120C1280,120,1120,120,960,120C800,120,640,120,480,120C320,120,160,120,80,120L0,120Z"></path>
    </svg>
  {% endif %}
</div>
