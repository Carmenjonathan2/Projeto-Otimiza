{% comment %}
  Renderiza o bloco unificado de GEO para a Coleção (Hero Text e FAQ) em formato Dropdown.
{% endcomment %}

{%- if collection.metafields.custom.geo_hero_text.value != blank or collection.metafields.custom.geo_faq.value != blank -%}
  <div class="geo-collection-dropdown-container" style="margin: 2rem 0; padding: 0 15px;">
    
    <details class="geo-main-accordion" style="background: #ffffff; border: 1px solid #e0e0e0; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.05); transition: all 0.3s ease;">
      
      <summary style="padding: 20px 25px; cursor: pointer; display: flex; align-items: center; list-style: none; outline: none; transition: background 0.2s;">
        <span style="display: flex; align-items: center; width: 100%; justify-content: space-between;">
          <span style="font-weight: 700; color: #470C51; font-size: 17px; display: flex; align-items: center;">
             <span style="background: #470C51; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 50%; margin-right: 12px; font-size: 12px;">✓</span>
             Saiba mais sobre {{ collection.title }}
          </span>
          <span class="accordion-icon" style="color: #6C0C51; font-weight: bold; font-size: 20px;">+</span>
        </span>
      </summary>

      <div class="geo-content-wrapper" style="padding: 0 25px 25px 25px; border-top: 1px solid #f0f0f0; background: #fafafa;">
        
        {%- if collection.metafields.custom.geo_hero_text.value != blank -%}
          <div class="geo-hero-text" style="font-size: 16px; color: #444; line-height: 1.7; margin-top: 20px; padding-bottom: 20px; border-bottom: 1px dashed #ddd;">
            {{ collection.metafields.custom.geo_hero_text.value }}
          </div>
        {%- endif -%}

        {%- if collection.metafields.custom.geo_faq.value != blank -%}
          <div class="geo-faq-list" style="margin-top: 25px;">
            <h3 style="font-size: 18px; color: #470C51; margin-bottom: 15px; font-weight: 700;">Dúvidas Frequentes</h3>
            
            {% for item in collection.metafields.custom.geo_faq.value %}
              <div class="geo-faq-sub-item" style="margin-bottom: 15px;">
                <p style="font-weight: 700; color: #333; margin-bottom: 5px; font-size: 15px;">Q: {{ item.pergunta }}</p>
                <p style="color: #666; font-size: 14px; line-height: 1.5; margin-left: 10px;">{{ item.resposta }}</p>
              </div>
            {% endfor %}
          </div>
        {%- endif -%}

      </div>
    </details>

    <style>
      .geo-main-accordion summary::-webkit-details-marker { display: none; }
      .geo-main-accordion[open] .accordion-icon { transform: rotate(45deg); display: inline-block; }
      .geo-main-accordion summary:hover { background: #f9f4fa; }
    </style>

  </div>

  {%- comment -%} Schema FAQPage para o Google continuar lendo os dados estruturados {%- endcomment -%}
  {%- if collection.metafields.custom.geo_faq.value != blank -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {% for item in collection.metafields.custom.geo_faq.value %}
        {
          "@type": "Question",
          "name": {{ item.pergunta | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ item.resposta | json }}
          }
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }
    </script>
  {%- endif -%}

{%- endif -%}
