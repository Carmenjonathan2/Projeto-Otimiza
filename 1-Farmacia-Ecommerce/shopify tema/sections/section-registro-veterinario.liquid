{% comment %}
  Seção para o formulário de registro de veterinários
{% endcomment %}

<div class="section-{{ section.id }}-padding">
  {% render 'snippet-registro-veterinario' %}
</div>

{% schema %}
{
  "name": "Registro de Veterinário",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Registro de Veterinário"
    }
  ]
}
{% endschema %}
