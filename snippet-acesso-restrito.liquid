{% comment %}
  Controle de Acesso Exclusivo para Veterinários
  Este snippet verifica se o cliente está logado e se possui a tag 'veterinario'.
{% endcomment %}

{%- liquid
  assign is_vet = false
  if customer
    for tag in customer.tags
      assign lower_tag = tag | downcase
      if lower_tag == 'veterinario'
        assign is_vet = true
      endif
    endfor
  endif
-%}

{%- unless is_vet -%}
  <div class="restriction-overlay">
    <div class="restriction-card">
      <div class="restriction-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#1a4d33" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      </div>
      <h2>Área Restrita: Médicos Veterinários</h2>
      <p>Esta página é dedicada exclusivamente a profissionais cadastrados e aprovados pela Otimiza FarmaVet.</p>
      
      <div class="restriction-actions">
        {%- if customer -%}
          <div class="status-badge alert">
            Aguardando aprovação do seu registro profissional.
          </div>
          <p class="status-note">Se você acabou de se cadastrar, nossa equipe verificará seu CRMV em breve.</p>
        {%- else -%}
          <a href="/account/login" class="button button--primary">Fazer Login</a>
          <a href="/pages/cadastro-veterinario" class="button button--secondary">Solicitar Acesso</a>
        {%- endif -%}
      </div>
      
      <a href="/" class="back-home">Retornar à loja pública</a>
    </div>
  </div>

  <style>
    .restriction-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(255, 255, 255, 0.98);
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    
    .restriction-card {
      max-width: 450px;
      text-align: center;
      padding: 40px;
      background: white;
      border-radius: 16px;
      box-shadow: 0 20px 50px rgba(0,0,0,0.1);
      border: 1px solid #f0f0f0;
    }
    
    .restriction-icon {
      margin-bottom: 20px;
    }
    
    .restriction-card h2 {
      color: #1a4d33;
      margin-bottom: 15px;
      font-size: 2.2rem;
    }
    
    .restriction-card p {
      color: #666;
      line-height: 1.6;
      margin-bottom: 25px;
    }
    
    .restriction-actions {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 20px;
    }
    
    .status-badge.alert {
      background: #fff8e1;
      color: #b78103;
      padding: 10px;
      border-radius: 6px;
      font-weight: 500;
    }
    
    .back-home {
      display: inline-block;
      margin-top: 15px;
      color: #999;
      text-decoration: underline;
      font-size: 1.3rem;
    }

    /* Esconde o conteúdo da página original enquanto não estiver logado */
    body { overflow: hidden; }
  </style>
  
  {%- comment -%} Para a execução do script se não for vet {%- endcomment -%}
  <script>
    window.stop();
    document.body.innerHTML = ''; // Limpeza extra de segurança
  </script>
{%- endunless -%}
