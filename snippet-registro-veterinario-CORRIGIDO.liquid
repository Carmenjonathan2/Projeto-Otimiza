{% comment %}
  Formulário de Registro Exclusivo para Médicos Veterinários - VERSÃO CORRIGIDA
  Tags corrigidas para formato compatível com Shopify
{% endcomment %}

<div class="vet-registration-wrapper">
  <div class="registration-container">
    <div class="registration-header">
      <h2>Cadastramento Profissional</h2>
      <p>Acesso exclusivo para Médicos Veterinários. Preencha os dados abaixo para análise de perfil.</p>
    </div>

    {%- form 'create_customer', class: 'vet-registration-form' -%}
      {%- if form.errors -%}
        <div class="form-errors">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="form-row">
        <div class="form-field">
          <label for="RegisterForm-FirstName">Nome *</label>
          <input
            type="text"
            name="customer[first_name]"
            id="RegisterForm-FirstName"
            {% if form.first_name %}value="{{ form.first_name }}"{% endif %}
            autocomplete="given-name"
            placeholder="Digite seu nome"
            required
          >
        </div>

        <div class="form-field">
          <label for="RegisterForm-LastName">Sobrenome *</label>
          <input
            type="text"
            name="customer[last_name]"
            id="RegisterForm-LastName"
            {% if form.last_name %}value="{{ form.last_name }}"{% endif %}
            autocomplete="family-name"
            placeholder="Digite seu sobrenome"
            required
          >
        </div>
      </div>

      <div class="form-field">
        <label for="RegisterForm-email">E-mail Profissional *</label>
        <input
          type="email"
          name="customer[email]"
          id="RegisterForm-email"
          {% if form.email %}value="{{ form.email }}"{% endif %}
          spellcheck="false"
          autocapitalize="off"
          autocomplete="email"
          aria-required="true"
          {% if form.errors contains 'email' %}
            aria-invalid="true"
            aria-describedby="RegisterForm-email-error"
          {% endif %}
          placeholder="seu.email@clinica.com.br"
          required
        >
      </div>

      <div class="form-row">
        <div class="form-field">
          <label for="RegisterForm-CRMV">Número do CRMV *</label>
          <input
            type="text"
            name="customer[note][CRMV]"
            id="RegisterForm-CRMV"
            placeholder="Ex: 12345/MG"
            pattern="[0-9]+/[A-Z]{2}"
            title="Formato: 12345/UF"
            required
          >
          <small class="field-hint">Formato: Número/UF (Ex: 12345/MG)</small>
        </div>

        <div class="form-field">
          <label for="RegisterForm-Phone">WhatsApp *</label>
          <input
            type="tel"
            name="customer[note][Telefone]"
            id="RegisterForm-Phone"
            placeholder="(31) 99999-9999"
            required
          >
        </div>
      </div>

      <div class="form-field">
        <label for="RegisterForm-password">Defina sua Senha *</label>
        <input
          type="password"
          name="customer[password]"
          id="RegisterForm-password"
          aria-required="true"
          {% if form.errors contains 'password' %}
            aria-invalid="true"
            aria-describedby="RegisterForm-password-error"
          {% endif %}
          placeholder="Mínimo 8 caracteres"
          minlength="8"
          required
        >
        <small class="field-hint">Mínimo de 8 caracteres</small>
      </div>

      {%- comment -%} 
        CORREÇÃO: Tags separadas em campos individuais para evitar problemas de parsing
        A Shopify aceita melhor múltiplas tags quando enviadas separadamente
      {%- endcomment -%}
      <input type="hidden" name="customer[tags]" value="vet-pendente">

      <div class="form-actions">
        <button type="submit" class="btn-submit">
          Solicitar Acesso à Área do Veterinário
        </button>
      </div>

      <p class="form-footer">
        Já possui cadastro? <a href="{{ routes.account_login_url }}">Fazer login</a>
      </p>

    {%- endform -%}

    <div class="info-box">
      <h3>📋 Processo de Aprovação</h3>
      <ol>
        <li>Preencha o formulário com seus dados profissionais</li>
        <li>Nossa equipe verificará seu CRMV em até 24 horas</li>
        <li>Você receberá um e-mail confirmando a aprovação</li>
        <li>Acesse o portal exclusivo com preços e produtos especiais</li>
      </ol>
    </div>
  </div>
</div>

<style>
.vet-registration-wrapper {
  padding: 60px 20px;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
}

.registration-container {
  max-width: 600px;
  margin: 0 auto;
  background: #ffffff;
  border-radius: 20px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.registration-header {
  background: linear-gradient(135deg, #1a4d33 0%, #2e7d32 100%);
  color: white;
  padding: 40px 35px;
  text-align: center;
}

.registration-header h2 {
  color: white;
  font-size: 2.8rem;
  font-weight: 700;
  margin: 0 0 12px 0;
}

.registration-header p {
  font-size: 1.5rem;
  margin: 0;
  opacity: 0.95;
}

.vet-registration-form {
  padding: 40px 35px;
}

.form-errors {
  background: #fee;
  border: 1px solid #fcc;
  border-radius: 8px;
  padding: 15px;
  margin-bottom: 25px;
  color: #c33;
  font-size: 1.4rem;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 20px;
}

.form-field {
  margin-bottom: 20px;
}

.form-field label {
  display: block;
  font-weight: 600;
  font-size: 1.4rem;
  color: #333;
  margin-bottom: 8px;
}

.form-field input {
  width: 100%;
  padding: 14px 16px;
  border: 2px solid #e0e0e0;
  border-radius: 8px;
  font-size: 1.5rem;
  transition: all 0.3s ease;
  background: #fafafa;
}

.form-field input:focus {
  border-color: #1a4d33;
  background: #ffffff;
  outline: none;
  box-shadow: 0 0 0 3px rgba(26, 77, 51, 0.1);
}

.field-hint {
  display: block;
  font-size: 1.2rem;
  color: #999;
  margin-top: 6px;
}

.form-actions {
  margin-top: 30px;
}

.btn-submit {
  width: 100%;
  padding: 16px 24px;
  background: linear-gradient(135deg, #1a4d33 0%, #2e7d32 100%);
  color: white;
  border: none;
  border-radius: 10px;
  font-size: 1.6rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.btn-submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(26, 77, 51, 0.3);
}

.btn-submit:active {
  transform: translateY(0);
}

.form-footer {
  text-align: center;
  margin-top: 25px;
  font-size: 1.4rem;
  color: #666;
}

.form-footer a {
  color: #1a4d33;
  font-weight: 700;
  text-decoration: none;
  transition: color 0.3s ease;
}

.form-footer a:hover {
  color: #2e7d32;
  text-decoration: underline;
}

.info-box {
  background: #f8f9fa;
  padding: 30px 35px;
  border-top: 1px solid #e9ecef;
}

.info-box h3 {
  color: #1a4d33;
  font-size: 1.8rem;
  margin: 0 0 15px 0;
}

.info-box ol {
  margin: 0;
  padding-left: 20px;
  color: #555;
}

.info-box li {
  font-size: 1.4rem;
  line-height: 1.8;
  margin-bottom: 8px;
}

@media (max-width: 768px) {
  .vet-registration-wrapper {
    padding: 30px 15px;
  }
  
  .registration-header {
    padding: 30px 25px;
  }
  
  .registration-header h2 {
    font-size: 2.2rem;
  }
  
  .vet-registration-form,
  .info-box {
    padding: 30px 25px;
  }
  
  .form-row {
    grid-template-columns: 1fr;
    gap: 0;
  }
}
</style>
