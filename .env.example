# ==========================================
# CONFIGURAÇÕES OTIMIZA FARMAVET — .env.example
# ==========================================
# Copie este arquivo para um novo arquivo chamado .env e preencha os valores.
# NUNCA comite o arquivo .env com valores reais!

# 1. TELEGRAM (Aika Bot)
# IMPORTANTE: Revogue o token antigo no BotFather e gere um novo.
TELEGRAM_BOT_TOKEN="insira_o_novo_token_aqui"
TELEGRAM_CHAT_IDS="6823632451,868045878"

# 2. WHATSAPP (Z-API)
ZAPI_INSTANCE_ID=""
ZAPI_TOKEN=""
ZAPI_CLIENT_TOKEN=""

# 3. GOOGLE APIs & OAUTH
# Client ID e Secret do Google Cloud Console (OAuth 2.0 Desktop)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_MAPS_API_KEY=""
GOOGLE_SHEET_ID=""
# Chave da API para Google Imagen / Vertex AI
GOOGLE_API_KEY=""

# 4. AI (GEMINI)
GEMINI_API_KEY=""

# 5. PINTEREST
PINTEREST_ACCESS_TOKEN=""

# 7. INSTAGRAM (além do TOKEN e ID_Instagram acima, necessário para o bot de comentários)
# Webhook
IG_WEBHOOK_VERIFY_TOKEN="seu_token_secreto_aqui"   # qualquer string, você define
IG_APP_SECRET=""                                    # App Secret do Meta Developer Dashboard

# 8. OUTROS (Futuros / Orquestração)
GITHUB_TOKEN=""
PAINEL_API_KEY=""
PORT=3001

# 9. MODO OPERACIONAL (IA Silenciosa / Modo Copiloto)
# "true" (default seguro) -> Intercepta envios de mensagens reais para clientes. Apenas salva como Nota Privada no Chatwoot.
# "false"                 -> IA responde ativamente e envia mensagens reais via WhatsApp para os clientes.
MODO_SILENCIOSO="true"

# 10. TEST WHITELIST (CRMV)
# Lista de CRMVs pré-aprovados separados por vírgula para testes automatizados. Vazio em produção.
CRMV_TEST_WHITELIST="15234,12345"

# 11. HARDENING DE CUSTO & OBSERVABILIDADE (Ciclo 4)
# Toggle de cache de system prompt (Gemini Context Caching).
# "true" liga (recomendado, economiza 60-75% input). "false" desliga para debug.
GEMINI_CACHE_ENABLED="true"

# Alertas de custo (em USD, somados no dia). Default seguro.
CUSTO_ALERTA_TELEGRAM_USD="2.00"   # avisa no Telegram
CUSTO_KILL_SWITCH_USD="10.00"      # ativa MODO_SILENCIOSO sozinho

# Rate-limit por telefone (proteção anti-abuso e anti-custo)
RATE_LIMIT_JANELA_SEGUNDOS="60"
RATE_LIMIT_MAX_MSG="8"

# 12. LIMPEZA DE ESTADOS (Ciclo 5)
# TTL em dias para expirar estados de conversa inativos no banco de dados local.
ESTADO_TTL_DIAS="60"

# 13. VALIDADOR SEMÂNTICO (Ciclo 6)
# Auditor pós-Gemini que checa cada resposta antes de enviar (preço inventado,
# persona errada, frases proibidas, vazamento de "fornecedor", etc.).
# "true" (default) audita. "false" desliga (economia em produção estável).
# Já é pulado automaticamente em MODO_SILENCIOSO=true.
VALIDADOR_SEMANTICO_ENABLED="true"

# 14. CACHE GESTAOCLICK (Ciclo 7)
# Cache em memória de buscas por CPF/CRMV/telefone no GestãoClick.
# Evita lookup repetido no ERP em conversas longas do mesmo cliente.
# Invalidado automaticamente quando cadastrarCliente é chamado.
GC_CACHE_ENABLED="true"
GC_CACHE_TTL_SECONDS="3600"

# 15. CREDENCIAIS GESTÃOCLICK (preenchidas no .env real)
GESTAOCLICK_ACCESS_TOKEN=""
GESTAOCLICK_SECRET_TOKEN=""

# 16. MODO CANARY (Ciclo 8)
# Porcentagem (0-100) de clientes que recebem resposta ATIVA mesmo com
# MODO_SILENCIOSO=true. Hash determinístico por phone — mesmo cliente cai
# sempre no mesmo grupo. Usar pra subir gradual: 5 → 10 → 25 → 50 → 100.
CANARY_PCT="0"

# 17. EXTRATOR DE PARES (Ciclo 8)
# Threshold Jaccard pra considerar que humano DIVERGIU da sugestão da IA.
# 0.5 = pares com menos de 50% de palavras em comum viram divergência.
PARES_SIMILARITY_THRESHOLD="0.5"

# 18. JANELA DE ATENDIMENTO (Ciclo 9)
# Fora desse horário (e domingo, se ATENDE_DOMINGO=false), bot responde só
# UMA vez por dia avisando que o atendimento volta no próximo dia útil.
HORARIO_COMERCIAL_INICIO="8"
HORARIO_COMERCIAL_FIM="20"
ATENDE_DOMINGO="false"

# 19. MOTOR DE RECOMPRA (Ciclo 9)
# Limite duro de envios diários do cron de recompra. Subir gradual conforme
# entender a aceitação (default 30 → testar com 5 nos primeiros dias).
RECOMPRA_MAX_ENVIOS_DIA="30"

# 20. LOCK DE CONCORRÊNCIA (Ciclo 10)
# Tempo (ms) que cada turno do mesmo phone bloqueia turnos paralelos. Evita
# 2 mensagens simultâneas processadas in race condition. Default 15s.
LOCK_PROCESSAMENTO_MS="15000"

# 21. PRIVACIDADE / LGPD (Ciclo 10)
# Mascara CPF, CNPJ, CRMV, email, CEP e telefones no conteúdo de mensagens
# antes de salvar em conversas_log.jsonl / validacoes_reprovadas.jsonl.
# Phone do campo identificador NÃO é mascarado (necessário pra cruzar).
MASCARAR_PII_ENABLED="true"

# 22. (reservado)

# 23. BACKUP DIÁRIO (Ciclo 10)
# Retenção em dias dos backups de conversas_state.json e few_shot_aprovados.json.
# BACKUP_RETENTION_DIAS="30"

# 24. ANIVERSÁRIOS DO PET (Ciclo 11)
# % de desconto do cupom Shopify único gerado no aniversário do pet (válido 7d).
ANIVERSARIO_DESCONTO_PCT="15"

# 25. NPS PÓS-COMPRA (Ciclo 11)
# Limite de envios diários da pesquisa NPS (D+3 dos pedidos pagos).
NPS_MAX_ENVIOS_DIA="20"

# 26. (reservado — histórico de compras via GestãoClick planejado)

# 27. LOGÍSTICA (Integrações de Entrega)
UBER_CLIENT_ID=""
UBER_CLIENT_SECRET=""

LALAMOVE_API_KEY=""
LALAMOVE_API_SECRET=""
TELEFONE_PRIVADO_CARMEN=""
