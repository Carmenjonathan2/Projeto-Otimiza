# ==========================================
# CONFIGURAÇÕES OTIMIZA FARMAVET — .env.example
# ==========================================
# Copie este arquivo para um novo arquivo chamado .env e preencha os valores.
# NUNCA comite o arquivo .env com valores reais!

# 1. TELEGRAM (Aika Bot)
# IMPORTANTE: Revogue o token antigo no BotFather e gere um novo.
TELEGRAM_BOT_TOKEN="insira_o_novo_token_aqui"
TELEGRAM_CHAT_IDS="6823632451,868045878"

# 2. WHATSAPP (Z-API ou Meta Cloud API)
WHATSAPP_API_TOKEN=""
WHATSAPP_INSTANCE_ID=""
Z_API_TOKEN=""
Z_API_INSTANCE_ID=""

# 3. GOOGLE APIs & OAUTH
# Client ID e Secret do Google Cloud Console (OAuth 2.0 Desktop)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_MAPS_API_KEY=""
GOOGLE_SHEET_ID=""
# Chave da API para Google Imagen / Vertex AI
GOOGLE_API_KEY=""

# 4. AI (GEMINI)
GEMINI_API_KEY=""

# 5. SHOPIFY
SHOPIFY_SHOP_URL="49mbh1-kp.myshopify.com"
SHOPIFY_ACCESS_TOKEN="shpat_..."
SHOPIFY_BLOG_ID="118332752160"

# 6. PINTEREST
PINTEREST_ACCESS_TOKEN=""

# 7. INSTAGRAM (além do TOKEN e ID_Instagram acima, necessário para o bot de comentários)
# Webhook
IG_WEBHOOK_VERIFY_TOKEN="seu_token_secreto_aqui"   # qualquer string, você define
IG_APP_SECRET=""                                    # App Secret do Meta Developer Dashboard

# 8. OUTROS (Futuros / Orquestração)
GITHUB_TOKEN=""
PAINEL_API_KEY=""
PORT=3001
