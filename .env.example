# ============================================================
# Variáveis de ambiente do Projeto Otimiza
# ============================================================
# COPIE este arquivo para .env e preencha com os valores reais.
# O .env NUNCA vai pro Git (já está no .gitignore).
# ============================================================

# ----- Shopify Admin API -----
# Domínio interno da loja (.myshopify.com), não o domínio público
SHOPIFY_STORE=otimizafarmavet.myshopify.com
# Token gerado em: Settings > Apps > Develop apps > Custom app
SHOPIFY_ADMIN_TOKEN=shpat_PREENCHER_AQUI
# Versão da Admin API (atualize quando o Shopify lançar nova)
SHOPIFY_API_VERSION=2025-01

# ----- Telegram (notificações) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_CARMEN=6823632451
TELEGRAM_CHAT_KYENNER=868045878

# ----- Anthropic (Aika / Claude Designer) -----
ANTHROPIC_API_KEY=

# ----- Google (Pinterest, Sheets, Gmail) -----
GOOGLE_CLIENT_SECRET_PATH=./client_secret.json
