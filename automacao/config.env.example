# ============================================================
# CONFIGURAÇÕES DA INTEGRAÇÃO META + BUFFER
# Copie este arquivo para "config.env" e preencha os valores
# NUNCA suba o arquivo config.env para o GitHub
# ============================================================

# --- META / INSTAGRAM ---
# Obtido em: developers.facebook.com > Seu App > Configurações > Básico
META_APP_ID=
META_APP_SECRET=

# Token de acesso de longa duração (60 dias) - veja GUIA-INTEGRACAO.md
META_ACCESS_TOKEN=

# ID do usuário Instagram Business - veja GUIA-INTEGRACAO.md
INSTAGRAM_USER_ID_KYENNER=
INSTAGRAM_USER_ID_OTIMIZA=

# --- BUFFER ---
# Obtido em: buffer.com > Settings > Apps & Integrations > Access Token
BUFFER_ACCESS_TOKEN=

# IDs dos perfis no Buffer (obtidos rodando: python3 automacao/buffer_listar_perfis.py)
BUFFER_PROFILE_ID_KYENNER=
BUFFER_PROFILE_ID_OTIMIZA=

# --- HOSPEDAGEM DE VÍDEO ---
# URL base onde os vídeos serão hospedados temporariamente
# Use Cloudinary (gratuito), Google Drive público, ou similar
CLOUDINARY_URL=
